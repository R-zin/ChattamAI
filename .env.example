# ---- Embeddings (OpenAI) ----
# Required: get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Optional: override the embedding model / proxy
# OPENAI_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---- LLM (Anthropic Claude) ----
# This project uses a local Claude proxy; the SDK reads these automatically.
ANTHROPIC_BASE_URL=http://127.0.0.1:8082
ANTHROPIC_AUTH_TOKEN=freecc
# Model served by your proxy (override if different)
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=2048

# ---- Data / retrieval ----
# Drop Kerala Building Rules PDFs/txt here (or set an absolute path)
KBR_DATA_DIR=./data/kbr
INDEX_DIR=./data/index
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=6
